<button
  id="theme-toggle"
  class="theme-toggle"
  aria-label="Toggle light/dark mode"
>
  <svg
    class="sun"
    aria-hidden="true"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <circle cx="12" cy="12" r="5"></circle><path d="M12 1v2"></path><path
      d="M12 21v2"></path><path d="M4.22 4.22l1.42 1.42"></path><path
      d="M18.36 18.36l1.42 1.42"></path><path d="M1 12h2"></path><path
      d="M21 12h2"></path><path d="M4.22 19.78l1.42-1.42"></path><path
      d="M18.36 5.64l1.42-1.42"></path>
  </svg>
  <svg
    class="moon"
    aria-hidden="true"
    width="20"
    height="20"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2.5"
    stroke-linecap="round"
    stroke-linejoin="round"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>

<style>
  .theme-toggle {
    background: var(--color-surface);
    border: var(--glass-border);
    padding: 0.6rem;
    border-radius: 12px;
    cursor: pointer;
    color: var(--color-text-main);
    transition: var(--transition-smooth);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
  }

  .theme-toggle:hover {
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-2px);
  }

  .sun {
    display: none;
  }
  .moon {
    display: block;
  }

  :global([data-theme="light"]) .sun {
    display: block;
  }
  :global([data-theme="light"]) .moon {
    display: none;
  }
</style>

<script is:inline>
  const handleToggle = () => {
    const isLight =
      document.documentElement.getAttribute("data-theme") === "light";
    const nextTheme = isLight ? "dark" : "light";
    document.documentElement.setAttribute("data-theme", nextTheme);
    localStorage.setItem("theme", nextTheme);
  };

  document
    .getElementById("theme-toggle")
    ?.addEventListener("click", handleToggle);
</script>
