---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/blog/PostCard.astro";
import { skills, blogPosts } from "../../data/siteData";

export async function getStaticPaths() {
  return [
    { params: { lang: "en" } },
    { params: { lang: "es" } },
    { params: { lang: "ca" } },
  ];
}

const { lang } = Astro.params;

// Simple translation logic for the prototype
const content: Record<string, any> = {
  en: {
    title: "Crafting Digital Excellence.",
    bio: "Senior Developer building high-performance web applications.",
    skills: "Technical Artistry",
    blog: "Latest Insights",
  },
  es: {
    title: "Creando Excelencia Digital.",
    bio: "Desarrollador Senior creando aplicaciones web de alto rendimiento.",
    skills: "Arte Técnico",
    blog: "Últimas Ideas",
  },
  ca: {
    title: "Creant Excel·lència Digital.",
    bio: "Desenvolupador Sènior creant aplicacions web d'alt rendiment.",
    skills: "Art Tècnic",
    blog: "Últimes Idees",
  },
};

const t = content[lang as string] || content.en;

const translations = [
  { uri: "/en/", langCode: "EN", langName: "English" },
  { uri: "/es/", langCode: "ES", langName: "Español" },
  { uri: "/ca/", langCode: "CA", langName: "Català" },
];
---

<BaseLayout
  title={`Carlos Matheu | ${lang!.toUpperCase()}`}
  description={t.bio}
  lang={lang as string}
  translations={translations}
>
  <section class="hero content-reveal">
    <div class="hero-content">
      <span class="badge"
        >{
          lang === "en" ? "Available for Projects" : "Disponible para Proyectos"
        }</span
      >
      <h1 id="hero-title" class="text-gradient">{t.title}</h1>
      <p class="hero-bio">{t.bio}</p>
      <div class="hero-actions">
        <a href="#contact" class="btn-primary">Contact</a>
        <a href="#skills" class="btn-secondary">Skills</a>
      </div>
    </div>
  </section>

  <section id="skills" class="section-padding">
    <div class="section-header">
      <h2>{t.skills} <span class="text-gradient">2026</span></h2>
    </div>
    <div class="skills-grid">
      {
        skills.map((skill) => (
          <article class="skill-card">
            <div class="skill-icon" aria-hidden="true">
              {skill.icon}
            </div>
            <div class="skill-content">
              <h3>{skill.title}</h3>
              <div class="progress-container">
                <div class="progress-bar" style={`width: ${skill.level}%`} />
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- 3. Blog Preview -->
  <section id="blog" class="section-padding" aria-labelledby="blog-heading">
    <div class="section-header">
      <div class="header-split">
        <h2 id="blog-heading">
          {t.blog}
          <span class="text-gradient">Insights</span>
        </h2>
        <a href={`/${lang}/blog`} class="link-more">View all articles →</a>
      </div>
    </div>

    <div class="blog-grid">
      {blogPosts.map((post) => <PostCard post={post} lang={lang as string} />)}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: 60vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .section-padding {
    padding: var(--space-l) 0;
  }
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }
  .skill-card {
    background: var(--color-surface);
    padding: 2rem;
    border-radius: 20px;
    border: var(--glass-border);
    display: flex;
    gap: 1rem;
    align-items: center;
  }
  .skill-icon {
    font-size: 2rem;
  }
  .progress-container {
    height: 4px;
    background: rgba(255, 255, 255, 0.1);
    width: 100%;
    margin-top: 10px;
    border-radius: 2px;
  }
  .progress-bar {
    height: 100%;
    background: var(--color-accent);
  }
  .badge {
    display: inline-block;
    padding: 0.5rem 1rem;
    background: var(--color-accent-soft);
    color: var(--color-accent);
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    border: 1px solid var(--color-accent);
  }
  .hero-bio {
    font-size: var(--step-0);
    color: var(--color-text-muted);
    margin: 2rem 0;
    line-height: 1.4;
  }
  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }
  .btn-primary,
  .btn-secondary {
    padding: 1rem 2rem;
    border-radius: 8px;
    font-weight: 700;
    text-decoration: none;
    transition: var(--transition-smooth);
  }
  .btn-primary {
    background: var(--color-accent);
    color: var(--color-bg);
  }
  .btn-secondary {
    border: var(--glass-border);
    color: var(--color-text-main);
  }

  /* Blog Preview Styles */
  .header-split {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
  }
  .link-more {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    transition: var(--transition-smooth);
  }
  .link-more:hover {
    letter-spacing: 0.1em;
  }

  .content-reveal {
    animation: reveal 0.8s cubic-bezier(0.23, 1, 0.32, 1) forwards;
  }
  @keyframes reveal {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
